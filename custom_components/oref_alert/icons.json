{
  "entity": {
    "binary_sensor": {
      "home_alert": {
        "default": "mdi:home-outline",
        "state": {
          "on": "mdi:home-alert-outline"
        }
      },
      "all_areas": {
        "default": "mdi:home-outline",
        "state": {
          "on": "mdi:home-alert-outline"
        }
      }
    },
    "sensor": {
      "default_time_to_shelter": {
        "default": "mdi:timer-sand"
      },
      "named_time_to_shelter": {
        "default": "mdi:timer-sand"
      },
      "default_end_time": {
        "default": "mdi:timer-sand-complete"
      },
      "named_end_time": {
        "default": "mdi:timer-sand-complete"
      },
      "default_status": {
        "default": "mdi:check-circle-outline",
        "state": {
          "pre_alert": "mdi:message-alert-outline",
          "alert": "mdi:home-alert-outline"
        }
      },
      "named_status": {
        "default": "mdi:check-circle-outline",
        "state": {
          "pre_alert": "mdi:message-alert-outline",
          "alert": "mdi:home-alert-outline"
        }
      }
    },
    "event": {
      "alert": {
        "default": "mdi:bullhorn-variant-outline"
      }
    }
  },
  "services": {
    "add_sensor": "mdi:map-marker-plus-outline",
    "remove_sensor": "mdi:map-marker-remove-outline",
    "edit_sensor": "mdi:map-marker-star-outline",
    "synthetic_alert": "mdi:rocket-launch"
  }
